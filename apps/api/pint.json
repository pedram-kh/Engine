{
  "preset": "laravel",
  "rules": {
    "declare_strict_types": true,
    "strict_param": true,
    "strict_comparison": true,
    "ordered_imports": {
      "sort_algorithm": "alpha"
    },
    "ordered_class_elements": {
      "order": [
        "use_trait",
        "case",
        "constant_public",
        "constant_protected",
        "constant_private",
        "property_public",
        "property_protected",
        "property_private",
        "construct",
        "destruct",
        "magic",
        "phpunit",
        "method_public",
        "method_protected",
        "method_private"
      ]
    },
    "no_unused_imports": true,
    "single_quote": true,
    "trailing_comma_in_multiline": {
      "elements": ["arrays", "arguments", "parameters"]
    }
  },
  "exclude": ["bootstrap/cache", "storage", "vendor"]
}
