{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "catalyst/api",
  "type": "project",
  "description": "Catalyst Engine API — Laravel 11 backend",
  "keywords": [
    "catalyst-engine",
    "laravel"
  ],
  "license": "proprietary",
  "require": {
    "php": "^8.4",
    "bacon/bacon-qr-code": "^3.1",
    "laravel/framework": "^11.31",
    "laravel/horizon": "^5.0",
    "laravel/pennant": "^1.0",
    "laravel/sanctum": "^4.3",
    "laravel/tinker": "^2.9",
    "pragmarx/google2fa": "^9.0",
    "predis/predis": "^3.4"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "larastan/larastan": "^3.9",
    "laravel/pail": "^1.1",
    "laravel/pint": "^1.13",
    "laravel/sail": "^1.26",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.1",
    "pestphp/pest": "^4.7",
    "pestphp/pest-plugin-laravel": "^4.1",
    "phpstan/phpstan-mockery": "^2.0",
    "phpunit/phpunit": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-install-cmd": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@php artisan key:generate --ansi"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ],
    "test": [
      "@php vendor/bin/pest --colors=always"
    ],
    "test:coverage": [
      "@php vendor/bin/pest --coverage --min=80"
    ],
    "pint": [
      "@php vendor/bin/pint"
    ],
    "pint:test": [
      "@php vendor/bin/pint --test"
    ],
    "stan": [
      "@php vendor/bin/phpstan analyse --memory-limit=2G"
    ],
    "ci": [
      "@pint:test",
      "@stan",
      "@test"
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185\" \"php artisan serve --host=127.0.0.1 --port=8000\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" --names=server,queue,logs"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
