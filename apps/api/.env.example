APP_NAME="Catalyst Engine"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

# Phase 1 supports en, pt, it (per docs/CURSOR-INSTRUCTIONS.md §10)
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_GB

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Postgres 16 via docker-compose at repo root
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=catalyst
DB_USERNAME=catalyst
DB_PASSWORD=catalyst

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=catalyst

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mailhog via docker-compose
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@catalystengine.local"
MAIL_FROM_NAME="${APP_NAME}"

# AWS / S3 — local defaults target MinIO (docker-compose). Staging/production
# values come from AWS Secrets Manager — see docs/SPRINT-0-MANUAL-STEPS.md.
# Buckets bootstrapped by `minio-init`: catalyst-engine-{media,contracts,exports,public}
AWS_ENDPOINT_URL=http://localhost:9100
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=catalyst-engine-media
AWS_USE_PATH_STYLE_ENDPOINT=true

# Sentry (DSN populated from AWS Secrets Manager in staging/production)
SENTRY_LARAVEL_DSN=

# Vendor API keys (mocks in dev; real keys come from AWS Secrets Manager in staging/production)
# All vendor-dependent features are gated behind feature flags — see docs/feature-flags.md
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=

META_OAUTH_APP_ID=
META_OAUTH_APP_SECRET=
TIKTOK_OAUTH_CLIENT_KEY=
TIKTOK_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

KYC_PROVIDER=mock
KYC_API_KEY=
KYC_WEBHOOK_SECRET=

ESIGN_PROVIDER=mock
ESIGN_API_KEY=
ESIGN_ACCOUNT_ID=

VITE_APP_NAME="${APP_NAME}"
