APP_NAME="Catalyst Engine"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

# Phase 1 supports en, pt, it (per docs/CURSOR-INSTRUCTIONS.md §10)
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_GB

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

# Password hashing — Argon2id per docs/05-SECURITY-COMPLIANCE.md §6.1.
# Cost parameters configured in config/hashing.php; tune via env if needed.
HASH_DRIVER=argon2id
HASH_ARGON_MEMORY=65536
HASH_ARGON_TIME=4
HASH_ARGON_THREADS=1

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Postgres 16 via docker-compose at repo root
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=catalyst
DB_USERNAME=catalyst
DB_PASSWORD=catalyst

# Session — Sanctum SPA cookies. SESSION_COOKIE defaults to
# 'catalyst_main_session'. The admin SPA gets 'catalyst_admin_session'
# at runtime via the UseAdminSessionCookie middleware (see
# docs/runbooks/local-dev.md). SESSION_DOMAIN is null in local dev so
# the cookie is bound to the request host (127.0.0.1); staging /
# production set it to the parent domain (e.g. .catalystengine.com)
# so the same cookie is valid on app.* and admin.* subdomains.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_COOKIE=catalyst_main_session
SESSION_SAME_SITE=lax

# Sanctum SPA stateful domains. Comma-separated list of origins that may
# initiate a stateful (cookie-bearing) request. In local dev these are the
# Vite dev servers for main + admin SPAs; staging/production override via
# AWS Secrets Manager.
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,127.0.0.1:5173,127.0.0.1:5174

# CORS allow-list. The two SPA dev servers; comma-separated extras allowed
# via FRONTEND_EXTRA_ORIGINS for tooling like Storybook.
FRONTEND_MAIN_URL=http://127.0.0.1:5173
FRONTEND_ADMIN_URL=http://127.0.0.1:5174
FRONTEND_EXTRA_ORIGINS=

# HaveIBeenPwned k-anonymity API. The client sends only the first 5
# characters of the SHA-1 hash; never the full hash, never the password.
# Override the base URL only for tests.
HIBP_API_URL=https://api.pwnedpasswords.com
HIBP_TIMEOUT=3

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=catalyst

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mailhog via docker-compose
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@catalystengine.local"
MAIL_FROM_NAME="${APP_NAME}"

# AWS / S3 — local defaults target MinIO (docker-compose). Staging/production
# values come from AWS Secrets Manager — see docs/SPRINT-0-MANUAL-STEPS.md.
# Buckets bootstrapped by `minio-init`: catalyst-engine-{media,contracts,exports,public}
#
# Per-disk bucket env vars (Sprint 3 Chunk 1, config/filesystems.php):
#   - media        → AWS_BUCKET_MEDIA      (private)
#   - contracts    → AWS_BUCKET_CONTRACTS  (private)
#   - exports      → AWS_BUCKET_EXPORTS    (private)
#   - media-public → AWS_BUCKET_PUBLIC     (public-read)
#
# AWS_BUCKET (singular) remains for the legacy 's3' disk + as a fallback
# default for AWS_BUCKET_MEDIA. New code should target one of the named
# disks, not the generic 's3' disk.
AWS_ENDPOINT_URL=http://localhost:9100
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=catalyst-engine-media
AWS_BUCKET_MEDIA=catalyst-engine-media
AWS_BUCKET_CONTRACTS=catalyst-engine-contracts
AWS_BUCKET_EXPORTS=catalyst-engine-exports
AWS_BUCKET_PUBLIC=catalyst-engine-public
AWS_USE_PATH_STYLE_ENDPOINT=true

# Sentry (DSN populated from AWS Secrets Manager in staging/production)
SENTRY_LARAVEL_DSN=

# Vendor API keys (mocks in dev; real keys come from AWS Secrets Manager in staging/production)
# All vendor-dependent features are gated behind feature flags — see docs/feature-flags.md
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=

META_OAUTH_APP_ID=
META_OAUTH_APP_SECRET=
TIKTOK_OAUTH_CLIENT_KEY=
TIKTOK_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

KYC_PROVIDER=mock
KYC_API_KEY=
KYC_WEBHOOK_SECRET=

ESIGN_PROVIDER=mock
ESIGN_API_KEY=
ESIGN_ACCOUNT_ID=

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Test helpers (E2E / Playwright)
# ---------------------------------------------------------------------------
# Shared secret for the App\TestHelpers module's `/api/v1/_test/*` routes.
# These routes are ONLY registered when APP_ENV is `local` or `testing` AND
# this token is non-empty (see app/TestHelpers/README.md). Production has
# no test-helper routes at all.
#
# Local dev: the value below is fine — the host is your laptop. Override
# per-developer if you prefer.
#
# CI: generate a fresh value per run, e.g.
#     TEST_HELPERS_TOKEN=$(openssl rand -hex 32)
# and inject it into BOTH the API container env AND the Playwright runner
# env. Never check a CI value into source control or ship a known token to
# any deployed environment.
TEST_HELPERS_TOKEN=local-dev-test-helpers-token-replace-me

