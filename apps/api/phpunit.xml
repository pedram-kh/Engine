<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <!-- Deterministic test-only encryption key. NOT a secret — committed
             intentionally so the test suite is hermetic and runs identically
             on a fresh clone, on CI, and on every developer's machine without
             depending on apps/api/.env. Production / staging keys come from
             AWS Secrets Manager (see docs/SPRINT-0-MANUAL-STEPS.md). -->
        <env name="APP_KEY" value="base64:SjJQVMrPc7nfaVPS4fIL71NxMj8lpAKwOl+o0YKwHgw="/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <!-- Argon2id with the lowest safe cost so the test suite runs fast.
             Production parameters are tuned in config/hashing.php. -->
        <env name="HASH_DRIVER" value="argon2id"/>
        <env name="HASH_ARGON_MEMORY" value="8192"/>
        <env name="HASH_ARGON_TIME" value="1"/>
        <env name="HASH_ARGON_THREADS" value="1"/>
        <!-- ============================================================
             TEST-PERFORMANCE-ONLY BCRYPT COST. DO NOT CARGO-CULT.
             ============================================================
             Bcrypt cost 4 is the absolute MINIMUM the library accepts.
             It is set here ONLY so the chunk-5 recovery-code hashing
             tests do not dominate the suite (~60s -> ~10s end-to-end).

             Production / staging / any non-test environment uses
             config('hashing.bcrypt.rounds'), which defaults to 12 per
             Laravel's framework default. Cost 4 must NEVER appear in
             .env.example, config/hashing.php, deployment manifests, or
             any other phpunit.xml-style override file.

             If you need to add a new bcrypt-related env var, leave it
             at the framework default and only override here for the
             same test-performance reason. -->
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
    </php>
</phpunit>
