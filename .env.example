# Root-level environment overrides for docker-compose.
#
# Copy to .env (gitignored) and override only if you have other services
# already bound to the default ports on your machine.
#
# These variables are read automatically by `docker compose up` because
# Compose loads `.env` from the project directory.

# Postgres host port mapping. Default 5432.
POSTGRES_HOST_PORT=5432

# Redis host port mapping. Default 6379.
REDIS_HOST_PORT=6379

# Mailhog host port mappings. Defaults 1025 (SMTP) / 8025 (UI).
MAILHOG_SMTP_HOST_PORT=1025
MAILHOG_UI_HOST_PORT=8025
