{
  "name": "@catalyst/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Catalyst Engine — typed API client (axios wrapper, shared by main and admin SPAs)",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "echo 'no lint yet' && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^2.1.9",
    "axios-mock-adapter": "^2.1.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.6.3",
    "vitest": "^2.1.8"
  }
}
