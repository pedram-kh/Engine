{
  "name": "@catalyst/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Catalyst Engine — shared Vue 3 component library (CButton, CTable, CField, …)",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./assets/fonts/inter.css": "./assets/fonts/inter.css",
    "./assets/fonts/*": "./assets/fonts/*"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "assets",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'no lint yet' && exit 0",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@catalyst/design-tokens": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vuetify": "^3.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.6.3",
    "vitest": "^2.1.8",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0",
    "vuetify": "^3.7.6"
  }
}
